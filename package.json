{
	"name": "svelte-starter",
	"version": "6.24.0",
	"scripts": {
		"gdoc": "node tasks/fetch-google.js",
		"style": "node tasks/style-dictionary.js",
		"scrolly-data": "node tasks/build-scrolly-nodes.js",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "prettier --check --plugin-search-dir=. .",
		"check": "svelte-check --tsconfig ./jsconfig.json",
		"spellcheck": "cspell \"src/data/**\" \"notes/**\" \"README.md\" \"src/routes/**/*.svelte\" \"src/components/Index.svelte\" \"src/components/Header.svelte\" \"src/components/Meta.svelte\"",
		"format": "prettier --write --plugin-search-dir=. .",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{js,svelte,json,css,md,html}": "prettier --write",
		"src/data/**": "cspell --no-must-find-files",
		"notes/**": "cspell --no-must-find-files",
		"README.md": "cspell --no-must-find-files",
		"src/routes/**/*.svelte": "cspell --no-must-find-files",
		"src/components/Index.svelte": "cspell --no-must-find-files",
		"src/components/Header.svelte": "cspell --no-must-find-files",
		"src/components/Meta.svelte": "cspell --no-must-find-files"
	},
	"devDependencies": {
		"@lucide/svelte": "^1.16.0",
		"@rollup/plugin-dsv": "^3.0.5",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"archieml": "^0.5.0",
		"autoprefixer": "^10.5.0",
		"bits-ui": "^2.18.1",
		"cspell": "^10.0.1",
		"d3": "^7.9.0",
		"lint-staged": "^17.0.8",
		"lodash.debounce": "^4.0.8",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"rollup": "^4.60.4",
		"rollup-plugin-svg": "^2.0.0",
		"runed": "^0.37.1",
		"simple-git-hooks": "^2.13.1",
		"style-dictionary": "^5.4.1",
		"svelte": "^5.55.9",
		"svelte-check": "^4.7.1",
		"svelte-preprocess": "^6.0.3",
		"typescript": "^5.9.3",
		"vite": "^8.0.13",
		"vite-plugin-svgstring": "^1.0.0"
	},
	"type": "module",
	"engines": {
		"node": ">= 22.22.0"
	},
	"browserslist": "> 0.5%, last 4 versions, not ie <= 11, not ie_mob <= 11"
}
